### Get All Users
# Returns all users (passwords excluded).
# Requires a valid Bearer JWT in Authorization header.
GET {{BASE_URL}}/api/user
Content-Type: application/json
Authorization: Bearer {{JWT_TOKEN}}

###

### Create User (Admin only)
# Creates a new user directly with email, name, password, and role.
# Requires an admin Bearer JWT in Authorization header.
POST {{BASE_URL}}/api/user
Content-Type: application/json
Authorization: Bearer {{JWT_TOKEN}}

{
  "email": "newuser@example.com",
  "name": "New User",
  "password": "supersecretpassword",
  "confirmPassword": "supersecretpassword",
  "role": "user"
}

###

### Get User By ID
# Returns a single user by their UUID (passwords excluded).
# Requires a valid Bearer JWT in Authorization header.
GET {{BASE_URL}}/api/user/{{USER_ID}}
Authorization: Bearer {{JWT_TOKEN}}
