# Server
NODE_ENV=development

# PostgreSQL — all connection details as individual parts
# The app builds the connection URL from these at runtime
POSTGRES_SERVER=localhost:5432
POSTGRES_DB=bun_boiler
POSTGRES_USER=bun_boiler_user
POSTGRES_PASSWORD=bun_boiler_pass

# Auth (used to sign and verify JWTs)
JWT_SECRET=your-secret-key-here

# Base URL of the app — used to build signup links
APP_URL=http://localhost:3000

# CORS — comma-separated list of allowed origins, or * to allow all
# Example: CORS_ORIGIN=https://app.example.com,https://staging.example.com
CORS_ORIGIN=*

# Seed — used by `bun run db:seed` to create the initial admin user
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-on-first-login
SEED_ADMIN_NAME=Admin

# E2E — used by Playwright global setup to seed and authenticate a test user
# Defaults are baked into e2e/global-setup.ts; override here if needed
E2E_TEST_EMAIL=e2e-playwright@local.test
E2E_TEST_PASSWORD=correct-horse-battery-staple-purple-elephant-dancing-at-midnight-with-seven-golden-penguins-in-antarctica-42
E2E_TEST_NAME=Playwright E2E User

# OpenTelemetry (optional — remove comments to enable)
# Start the local SigNoz stack first: docker compose -f docker-compose.signoz.yml up -d
# OTEL_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=bun-boiler

# OpenPanel Analytics (optional — remove comments to enable)
# Start the local OpenPanel stack first: docker compose -f docker-compose.openpanel.yml up -d
# Then open http://localhost:7780, create an account, add a project, and copy its Client ID below.
# BUN_PUBLIC_OPENPANEL_CLIENT_ID=your-client-id
# BUN_PUBLIC_OPENPANEL_API_URL=http://localhost:3001  # only needed for self-hosted
# BUN_PUBLIC_OPENPANEL_SESSION_REPLAY=false

# OpenPanel Docker stack secrets (only needed when running docker-compose.openpanel.yml)
# OP_COOKIE_SECRET=change-me-openpanel-secret-32chars!
# OP_POSTGRES_PASSWORD=openpanel_pass
# OP_DASHBOARD_URL=http://localhost:7780
# OP_API_URL=http://localhost:3001

# SMTP Mail (optional — uncomment to enable)
# Any SMTP provider works: Gmail, Mailgun, Resend, Postmark, or local Mailpit for dev.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=secret
# SMTP_FROM=My App <no-reply@example.com>
# SMTP_SECURE=false
