{
  "name": "wise-geoguessr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot server/server.ts",
    "start": "NODE_ENV=production bun server/server.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "bunx --bun oxlint --type-aware --type-check",
    "format:check": "bunx oxfmt --check",
    "format": "bunx oxfmt",
    "cc": "bun test && bun lint && bun format:check",
    "prepare": "husky",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:push": "bunx --bun drizzle-kit check && bunx --bun drizzle-kit push",
    "db:seed": "bun server/db/seed.ts",
    "db:studio": "bunx --bun drizzle-kit studio"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.27.5",
    "@mui/x-data-grid": "^8.27.5",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.0",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@happy-dom/global-registrator": "^20.8.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "latest",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.9",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "oxlint": "^1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "postcss": "^8.5.8",
    "tsx": "^4.21.0"
  }
}
