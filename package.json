{
  "name": "wise-geoguessr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot backend/server.ts",
    "start": "NODE_ENV=production bun backend/server.ts",
    "build": "bun run build.ts",
    "test": "bun test ./backend ./frontend",
    "test:watch": "bun test --watch ./backend ./frontend",
    "lint": "bunx oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "lint:compiler": "bunx eslint --config eslint.config.js 'frontend/**/*.{ts,tsx,js,jsx}'",
    "format:check": "bunx oxfmt --check",
    "format": "bunx oxfmt",
    "cc": "bun test ./backend ./frontend && bun lint && bun lint:compiler && bun format:check && bun knip",
    "knip": "knip-bun",
    "prepare": "husky",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:seed": "bun backend/db/seed.ts",
    "db:push": "bunx --bun drizzle-kit check && bunx --bun drizzle-kit push",
    "db:studio": "bunx --bun drizzle-kit studio",
    "e2e": "playwright test --project=api",
    "e2e:browser": "playwright test --project=browser",
    "e2e:all": "playwright test --project=api && playwright test --project=browser",
    "e2e:ui": "playwright test --ui --project=api --project=browser",
    "e2e:debug": "playwright test --debug",
    "e2e:docker": "./scripts/e2e-ci.sh",
    "e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.28.2",
    "@mui/x-data-grid": "^8.28.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-fetch": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/sdk-trace-web": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@rybbit/js": "^0.6.2",
    "canvas-confetti": "^1.9.4",
    "dayjs": "^1.11.20",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "husky": "^9.1.7",
    "jose": "^6.2.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "postgres": "^3.4.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-redux": "^9.2.0",
    "react-router": "^7.14.0",
    "react-toastify": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@happy-dom/global-registrator": "^20.8.9",
    "@playwright/test": "^1.59.1",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "latest",
    "@types/canvas-confetti": "^1.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "knip": "^6.2.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript-eslint": "^8.58.0"
  }
}
